FROM python:3.9-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ ./backend/
COPY models/ ./models/

ENV PYTHONPATH=/app
ENV PORT=5000

EXPOSE 5000

# Run with uvicorn for FastAPI
CMD ["uvicorn", "backend.app:app", "--host", "0.0.0.0", "--port", "5000"]